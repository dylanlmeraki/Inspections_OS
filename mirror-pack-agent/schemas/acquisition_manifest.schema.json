{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "source_record_key",
    "requested_url",
    "requested_urls",
    "final_url",
    "status",
    "fetched_at",
    "discovered_pdf_links",
    "fetch_attempts"
  ],
  "properties": {
    "source_record_key": {"type": "string"},
    "requested_url": {"type": "string"},
    "requested_urls": {"type": "array", "items": {"type": "string"}},
    "final_url": {"type": ["string", "null"]},
    "status": {
      "type": "string",
      "enum": [
        "direct_mirror_downloaded",
        "source_reference_verified",
        "html_page_snapshotted",
        "pdf_link_discovered_not_downloaded",
        "requires_manual_login",
        "requires_manual_review",
        "ambiguous_source",
        "superseded_source",
        "obsolete_source",
        "http_error",
        "wrong_content_type",
        "fetch_failed"
      ]
    },
    "fetched_at": {"type": "string"},
    "content_type": {"type": ["string", "null"]},
    "sha256": {"type": ["string", "null"]},
    "file_size": {"type": ["integer", "null"]},
    "stored_path": {"type": ["string", "null"]},
    "page_title": {"type": ["string", "null"]},
    "notes": {"type": ["string", "null"]},
    "http_status": {"type": ["integer", "null"]},
    "redirect_chain": {"type": "array", "items": {"type": "string"}},
    "source_type_detected": {"type": ["string", "null"]},
    "local_file_name": {"type": ["string", "null"]},
    "jurisdiction_name": {"type": ["string", "null"]},
    "program_label": {"type": ["string", "null"]},
    "aliases": {"type": "array", "items": {"type": "string"}},
    "discovered_pdf_links": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["text", "url", "status"],
        "properties": {
          "text": {"type": "string"},
          "url": {"type": "string"},
          "final_url": {"type": ["string", "null"]},
          "status": {
            "type": "string",
            "enum": [
              "direct_mirror_downloaded",
              "pdf_link_discovered_not_downloaded",
              "requires_manual_login",
              "requires_manual_review",
              "http_error",
              "wrong_content_type",
              "fetch_failed"
            ]
          },
          "stored_path": {"type": ["string", "null"]},
          "content_type": {"type": ["string", "null"]},
          "sha256": {"type": ["string", "null"]},
          "file_size": {"type": ["integer", "null"]},
          "http_status": {"type": ["integer", "null"]},
          "notes": {"type": ["string", "null"]}
        }
      }
    },
    "fetch_attempts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["requested_url", "status"],
        "properties": {
          "requested_url": {"type": "string"},
          "final_url": {"type": ["string", "null"]},
          "http_status": {"type": ["integer", "null"]},
          "content_type": {"type": ["string", "null"]},
          "redirect_chain": {"type": "array", "items": {"type": "string"}},
          "status": {"type": "string"},
          "stored_path": {"type": ["string", "null"]},
          "sha256": {"type": ["string", "null"]},
          "file_size": {"type": ["integer", "null"]},
          "page_title": {"type": ["string", "null"]},
          "notes": {"type": ["string", "null"]},
          "source_type_detected": {"type": ["string", "null"]}
        }
      }
    }
  }
}
